NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional fallback if you already use this non-standard key name:
# NEXT_PUBLIC_SUPABASE_SERVICE_KEY=your-supabase-service-role-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
OAUTH_STATE_SECRET=replace-with-a-long-random-secret
OAUTH_STATE_TTL_SECONDS=600
CORS_ORIGINS=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-secret
# Set true only for local development.
ALLOW_INSECURE_CRON=false
